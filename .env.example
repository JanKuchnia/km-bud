# KM-BUD Environment Variables — EXAMPLE TEMPLATE
# Copy this file to .env and fill in real values.
# .env is git-ignored and must never be committed.

# Environment: 'development' (local) or 'production' (Hostinger)
# development → shows PHP errors, verbose API messages, skips TinyPNG compression
# production  → hides errors, generic messages, full TinyPNG compression enabled
APP_ENV=production

# Database
DB_HOST=localhost
DB_NAME=kmbud
DB_USER=root
DB_PASS=
DB_CHARSET=utf8mb4

# Admin Panel
# Generate with: php -r "echo password_hash('your_password', PASSWORD_BCRYPT, ['cost'=>12]);"
ADMIN_PASSWORD_HASH=

# TinyPNG Image Compression (https://tinypng.com/developers)
TINYPNG_API_KEY=

# Google Places Reviews (https://console.cloud.google.com)
GOOGLE_PLACES_API_KEY=
GOOGLE_PLACES_PLACE_ID=
